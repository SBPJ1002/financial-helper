generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  fullName            String
  password            String
  role                Role                 @default(USER)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  cpf                 String?
  cpfHash             String?              @unique
  birthDate           DateTime?
  gender              Gender?
  emailVerified       Boolean              @default(false)
  lastLoginAt         DateTime?
  zipCode             String?
  street              String?
  addressNumber       String?
  complement          String?
  neighborhood        String?
  city                String?
  state               String?
  pluggyItems         PluggyItem[]
  categories          Category[]
  chatMessages        ChatMessage[]
  classificationRules ClassificationRule[]
  expenses            Expense[]
  incomes             Income[]
  notifications       Notification[]
  recurrenceGroups    RecurrenceGroup[]
  sessions            Session[]
  settings            UserSettings?
  plan                Plan                 @default(FREE)
  financialProfile    UserFinancialProfile?
  declarations        FixedExpenseDeclaration[]
  invoicePayments     InvoicePayment[]
  stdCounterparts     StdCounterpart[]

  @@map("users")
}

model UserFinancialProfile {
  id                      String       @id @default(cuid())
  userId                  String       @unique
  primaryGoal             UserGoal?
  financialControlScore   Int?
  bankAccountCount        Int?
  creditCardCount         Int?
  preferredPaymentMethods String[]
  incomeType              IncomeType?
  expectedIncomeDay       Int?
  incomeRange             IncomeRange?
  incomeIsVariable        Boolean      @default(false)
  housingType             HousingType?
  hasDependents           Boolean      @default(false)
  dependentTypes          String[]
  expectedFixedExpenses   String[]
  onboardingCompleted     Boolean      @default(false)
  onboardingCompletedAt   DateTime?
  onboardingStepReached   Int          @default(0)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_financial_profiles")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ============================================================
// RAW LAYER — Exact Pluggy data, never altered after initial save
// ============================================================

model PluggyItem {
  id              String    @id @default(cuid())
  userId          String
  pluggyItemId    String    @unique
  connectorId     Int?
  connectorName   String
  status          String    @default("ACTIVE")
  executionStatus String?
  lastSyncedAt    DateTime?
  syncCount       Int       @default(0)
  rawJson         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts        PluggyAccount[]

  @@index([userId])
  @@map("pluggy_items")
}

model PluggyAccount {
  id                   String    @id @default(cuid())
  pluggyItemId         String
  pluggyAccountId      String    @unique
  name                 String
  type                 String
  subtype              String?
  number               String?
  balance              Float     @default(0)
  currencyCode         String    @default("BRL")
  creditLimit          Float?
  availableCreditLimit Float?
  marketingName        String?
  rawJson              String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  pluggyItem           PluggyItem @relation(fields: [pluggyItemId], references: [id], onDelete: Cascade)
  transactions         PluggyTransaction[]
  stdAccount           StdAccount?

  @@index([pluggyItemId])
  @@map("pluggy_accounts")
}

model PluggyTransaction {
  id                   String    @id @default(cuid())
  pluggyAccountId      String
  pluggyTxId           String    @unique
  description          String
  descriptionRaw       String?
  amount               Float
  date                 DateTime
  type                 String
  category             String?
  categoryId           String?
  operationType        String?
  currencyCode         String    @default("BRL")
  // Credit card metadata
  installmentNumber    Int?
  totalInstallments    Int?
  cardNumber           String?
  billDate             DateTime?
  // Payer info
  payerName            String?
  payerDocType         String?
  payerDocValue        String?
  // Receiver info
  receiverName         String?
  receiverDocType      String?
  receiverDocValue     String?
  // Merchant info
  merchantName         String?
  merchantBusinessName String?
  merchantCnpj         String?
  merchantCategoryCode String?
  // Payment method from Pluggy
  paymentMethod        String?
  // Processing status
  isProcessed          Boolean   @default(false)
  processingError      String?
  rawJson              String?
  createdAt            DateTime  @default(now())
  pluggyAccount        PluggyAccount @relation(fields: [pluggyAccountId], references: [id], onDelete: Cascade)
  stdTransaction       StdTransaction?

  @@index([pluggyAccountId, date])
  @@index([isProcessed])
  @@map("pluggy_transactions")
}

// ============================================================
// STANDARDIZED LAYER — Clean, normalized, flagged
// ============================================================

model StdAccount {
  id                  String         @id @default(cuid())
  pluggyAccountId     String         @unique
  userId              String
  sourceType          StdSourceType  @default(BANK)
  bankName            String
  accountLabel        String
  accountNumberMasked String?
  currentBalance      Float          @default(0)
  currencyCode        String         @default("BRL")
  creditLimit         Float?
  billingCycleDay     Int?
  isActive            Boolean        @default(true)
  isPrimary           Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  pluggyAccount       PluggyAccount  @relation(fields: [pluggyAccountId], references: [id], onDelete: Cascade)
  transactions        StdTransaction[]
  creditInvoices      StdCreditInvoice[]
  declarations        FixedExpenseDeclaration[]
  invoicePayments     InvoicePayment[] @relation("invoicePaymentStdAccount")

  @@index([userId])
  @@map("std_accounts")
}

model StdCounterpart {
  id               String    @id @default(cuid())
  userId           String
  document         String
  documentType     DocumentType
  displayName      String
  rawNames         String[]
  mccCode          String?
  transactionCount Int       @default(0)
  avgAmount        Float     @default(0)
  isRecurring      Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     StdTransaction[]

  @@unique([userId, document])
  @@map("std_counterparts")
}

model StdTransaction {
  id                    String                    @id @default(cuid())
  pluggyTransactionId   String                    @unique
  stdAccountId          String
  userId                String
  descriptionOriginal   String
  descriptionClean      String
  direction             TransactionDirection
  absoluteAmount        Float
  date                  DateTime
  currencyCode          String                    @default("BRL")
  // Payment info
  paymentMethod         StdPaymentMethod          @default(OTHER)
  // Counterpart (denormalized for fast queries)
  counterpartName       String?
  counterpartDocument   String?
  counterpartId         String?
  // Installments
  installmentGroupId    String?
  installmentNumber     Int?
  totalInstallments     Int?
  // Flags
  isInternalTransfer    Boolean                   @default(false)
  isInvoicePayment      Boolean                   @default(false)
  isRefund              Boolean                   @default(false)
  isSalaryCandidate     Boolean                   @default(false)
  // Classification
  classificationStatus  StdClassificationStatus   @default(PENDING)
  classificationSource  String?
  confidenceScore       Float?
  reviewStatus          String?
  // App linkage
  imported              Boolean                   @default(false)
  recurrenceGroupId     String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  pluggyTransaction     PluggyTransaction         @relation(fields: [pluggyTransactionId], references: [id], onDelete: Cascade)
  stdAccount            StdAccount                @relation(fields: [stdAccountId], references: [id], onDelete: Cascade)
  counterpart           StdCounterpart?           @relation(fields: [counterpartId], references: [id])
  recurrenceGroup       RecurrenceGroup?          @relation(fields: [recurrenceGroupId], references: [id])
  expense               Expense?
  income                Income?
  declarationMatches    DeclarationMatch[]
  invoicePayment        InvoicePayment?

  @@index([stdAccountId, date])
  @@index([userId, date])
  @@index([userId, imported])
  @@index([installmentGroupId])
  @@index([recurrenceGroupId])
  @@map("std_transactions")
}

model StdCreditInvoice {
  id             String     @id @default(cuid())
  stdAccountId   String
  referenceMonth String
  closeDate      DateTime?
  dueDate        DateTime?
  totalAmount    Float      @default(0)
  minimumPayment Float?
  isPaid         Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  stdAccount     StdAccount @relation(fields: [stdAccountId], references: [id], onDelete: Cascade)

  @@unique([stdAccountId, referenceMonth])
  @@map("std_credit_invoices")
}

// ============================================================
// APP LAYER — Existing models with new FK columns
// ============================================================

model Income {
  id                String           @id @default(cuid())
  userId            String
  description       String
  amount            Float
  date              DateTime
  recurrence        Recurrence       @default(MONTHLY)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  stdTransactionId  String?          @unique
  categoryId        String?
  contractMonths    Int?
  contractStartDate DateTime?
  importBatchId     String?
  recurrenceDay     Int?
  currency          String           @default("BRL")
  stdTransaction    StdTransaction?  @relation(fields: [stdTransactionId], references: [id])
  category          Category?        @relation(fields: [categoryId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("incomes")
}

model Category {
  id        String       @id @default(cuid())
  userId    String?
  name      String
  emoji     String       @default("")
  isDefault Boolean      @default(false)
  type      CategoryType @default(EXPENSE)
  user      User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses  Expense[]
  incomes   Income[]

  @@unique([userId, name])
  @@map("categories")
}

model Expense {
  id                 String           @id @default(cuid())
  userId             String
  description        String
  amount             Float
  type               ExpenseType
  categoryId         String
  date               DateTime
  dueDay             Int?
  status             ExpenseStatus    @default(PENDING)
  paymentMethod      PaymentMethod?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  stdTransactionId   String?          @unique
  installmentGroupId String?
  installmentNumber  Int?
  totalInstallments  Int?
  fixedAmountType    FixedAmountType?
  importBatchId      String?
  currency           String           @default("BRL")
  goal               ExpenseGoal?
  history            ExpenseHistory[]
  stdTransaction     StdTransaction?  @relation(fields: [stdTransactionId], references: [id])
  category           Category         @relation(fields: [categoryId], references: [id])
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([installmentGroupId])
  @@map("expenses")
}

model ExpenseHistory {
  id        String   @id @default(cuid())
  expenseId String
  month     String
  amount    Float
  createdAt DateTime @default(now())
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([expenseId, month])
  @@index([expenseId])
  @@map("expense_history")
}

model ExpenseGoal {
  id        String  @id @default(cuid())
  expenseId String  @unique
  limit     Float
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@map("expense_goals")
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  aiProvider           String   @default("google")
  aiApiKey             String?
  aiModel              String   @default("auto")
  theme                String   @default("dark")
  accentColor          String   @default("blue")
  language             String   @default("pt-BR")
  fontSize             String   @default("medium")
  currency             String   @default("BRL")
  dateFormat           String   @default("DD/MM/YYYY")
  startDayOfMonth      Int      @default(1)
  alertExpenseAbove    Boolean  @default(true)
  alertInvestmentDrop  Boolean  @default(true)
  alertBillDue         Boolean  @default(true)
  aiIncludeExpenses    Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model RecurrenceGroup {
  id                 String            @id @default(cuid())
  userId             String
  label              String
  counterpartPattern String?
  amountAvg          Float
  amountTolerance    Float             @default(0.15)
  dayOfMonthAvg      Int?
  dayTolerance       Int               @default(5)
  transactionType    String            @default("fixed_expense")
  categoryName       String?
  occurrenceCount    Int               @default(0)
  firstSeenAt        DateTime
  lastSeenAt         DateTime
  isActive           Boolean           @default(true)
  confirmedByUser    Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       StdTransaction[]

  @@index([userId])
  @@map("recurrence_groups")
}

model ClassificationRule {
  id                       String   @id @default(cuid())
  userId                   String
  matchCounterpartDocument String?
  matchCounterpartName     String?
  matchDescriptionContains String?
  matchPaymentMethod       String?
  matchAmountMin           Float?
  matchAmountMax           Float?
  transactionType          String
  categoryName             String?
  customLabel              String?
  priority                 Int      @default(100)
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("classification_rules")
}

model KeywordMapping {
  id              String  @id @default(cuid())
  keyword         String
  matchField      String  @default("normalized_description")
  matchType       String  @default("contains")
  transactionType String
  categoryName    String?
  confidenceBoost Float   @default(0.50)
  isActive        Boolean @default(true)

  @@map("keyword_mappings")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chat_messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  metadata  String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model SystemMetric {
  id        String   @id @default(cuid())
  key       String
  value     String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([key, createdAt])
  @@map("system_metrics")
}

model FixedExpenseDeclaration {
  id                        String                   @id @default(cuid())
  userId                    String
  label                     String
  categoryName              String?
  paymentMethod             DeclarationPaymentMethod
  creditAccountId           String?
  estimatedAmount           Float
  amountTolerance           Float                    @default(0.15)
  expectedDay               Int?
  dayTolerance              Int                      @default(5)
  matchKeywords             String[]
  matchCounterpartDocument  String?
  isActive                  Boolean                  @default(true)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  user                      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditAccount             StdAccount?              @relation(fields: [creditAccountId], references: [id])
  matches                   DeclarationMatch[]

  @@index([userId])
  @@map("fixed_expense_declarations")
}

model DeclarationMatch {
  id                String                  @id @default(cuid())
  declarationId     String
  stdTransactionId  String
  strategy          MatchStrategy
  confidenceScore   Float
  month             String
  matchedAmount     Float
  isConfirmed       Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  declaration       FixedExpenseDeclaration  @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  stdTransaction    StdTransaction          @relation(fields: [stdTransactionId], references: [id], onDelete: Cascade)

  @@unique([declarationId, month])
  @@unique([stdTransactionId, declarationId])
  @@map("declaration_matches")
}

model InvoicePayment {
  id                  String          @id @default(cuid())
  userId              String
  stdTransactionId    String          @unique
  stdAccountId        String
  amount              Float
  month               String
  detectedDescription String
  createdAt           DateTime        @default(now())
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stdTransaction      StdTransaction  @relation(fields: [stdTransactionId], references: [id], onDelete: Cascade)
  stdAccount          StdAccount      @relation("invoicePaymentStdAccount", fields: [stdAccountId], references: [id])

  @@map("invoice_payments")
}

// ============================================================
// ENUMS
// ============================================================

enum Plan {
  FREE
  AI_AGENT
  FULL
}

enum Role {
  USER
  ADMIN
}

enum ExpenseType {
  FIXED
  VARIABLE
}

enum PaymentMethod {
  CASH
  CREDIT
  DEBIT
  PIX
}

enum ExpenseStatus {
  PAID
  PENDING
}

enum Recurrence {
  MONTHLY
  ONE_TIME
  CONTRACT
}

enum CategoryType {
  EXPENSE
  INCOME
  BOTH
}

enum FixedAmountType {
  FIXED_AMOUNT
  VARIABLE_AMOUNT
}

enum NotificationType {
  BILL_DUE
  EXPENSE_ABOVE
  VARIABLE_AMOUNT_NEEDED
  CONTRACT_ENDING
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum DeclarationPaymentMethod {
  PIX
  BOLETO
  AUTO_DEBIT
  CREDIT_CARD
}

enum MatchStrategy {
  CNPJ_EXACT
  KEYWORD
  FUZZY_NAME
  AMOUNT_RECURRENCE
}

enum UserGoal {
  SAVE_MORE
  PAY_OFF_DEBT
  CONTROL_SPENDING
  INVEST_MORE
  BUILD_EMERGENCY_FUND
}

enum IncomeType {
  CLT
  SELF_EMPLOYED
  FREELANCER
  BUSINESS_OWNER
  RETIREMENT
  OTHER_INCOME
}

enum HousingType {
  OWN_PAID
  OWN_MORTGAGE
  RENT
  FAMILY
}

enum IncomeRange {
  UP_TO_2K
  FROM_2K_TO_5K
  FROM_5K_TO_10K
  FROM_10K_TO_20K
  ABOVE_20K
}

// New enums for 3-layer architecture

enum TransactionDirection {
  CREDIT
  DEBIT
}

enum StdPaymentMethod {
  PIX
  BOLETO
  CREDIT_CARD
  DEBIT_CARD
  AUTO_DEBIT
  TRANSFER
  CASH
  OTHER
}

enum StdClassificationStatus {
  PENDING
  AUTO_CLASSIFIED
  USER_CONFIRMED
  USER_CORRECTED
}

enum StdSourceType {
  BANK
  CREDIT
  INVESTMENT
}

enum DocumentType {
  CPF
  CNPJ
}
